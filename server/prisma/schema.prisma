// Схема соответствует укрупнённой модели данных из SRS (раздел 6.1).
// В Этапе 1 реально используется только User + AuditLogEntry (аутентификация).
// Остальные модели зафиксированы заранее, чтобы не переделывать миграции на Этапах 2-9.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  SPEAKER
}

enum SlideStatus {
  DRAFT
  SUBMITTED
  NEEDS_REVISION
  IN_PRESENTATION
}

enum WeeklyCycleStatus {
  COLLECTING
  ASSEMBLED
  ARCHIVED
}

enum LayoutKind {
  QUADRANT
  FINANCIAL_CHART
  SIMPLE_COLUMN
}

enum BlockType {
  METRIC_TILE
  RICH_TEXT_SECTION
  TABLE
  FOOTER_STATS
  CHART_IMAGE
}

enum NotificationType {
  CYCLE_ASSEMBLED
  CYCLE_ARCHIVED
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  login        String   @unique
  passwordHash String
  role         UserRole @default(SPEAKER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates     Template[]      @relation("TemplateOwner")
  slides        Slide[]
  auditEntries  AuditLogEntry[]
  notifications Notification[]
}

model Template {
  id         String      @id @default(uuid())
  name       String
  isShared   Boolean     @default(false)
  version    Int         @default(1)
  createdBy  String?
  owner      User?       @relation("TemplateOwner", fields: [createdBy], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  layoutKind LayoutKind?

  fields TemplateField[]
  blocks TemplateBlock[]
  slides Slide[]
}

model TemplateField {
  id         String   @id @default(uuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  isRequired Boolean  @default(false)
  order      Int      @default(0)

  values SlideFieldValue[]
}

model TemplateBlock {
  id         String    @id @default(uuid())
  templateId String
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  blockType  BlockType
  label      String
  isRequired Boolean   @default(false)
  order      Int       @default(0)
  config     Json?

  values SlideBlockValue[]
}

model WeeklyCycle {
  id        String            @id @default(uuid())
  weekLabel String
  startDate DateTime
  endDate   DateTime
  deadline  DateTime?
  status    WeeklyCycleStatus @default(COLLECTING)

  slides        Slide[]
  presentation  Presentation?
  notifications Notification[]
}

model Slide {
  id            String      @id @default(uuid())
  weeklyCycleId String
  weeklyCycle   WeeklyCycle @relation(fields: [weeklyCycleId], references: [id])
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id])
  templateId    String
  template      Template    @relation(fields: [templateId], references: [id])
  status        SlideStatus @default(DRAFT)
  reviewComment String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  fieldValues       SlideFieldValue[]
  blockValues       SlideBlockValue[]
  presentationSlide PresentationSlide?
}

model SlideFieldValue {
  id              String        @id @default(uuid())
  slideId         String
  slide           Slide         @relation(fields: [slideId], references: [id], onDelete: Cascade)
  templateFieldId String
  templateField   TemplateField @relation(fields: [templateFieldId], references: [id])
  value           String        @default("")

  history FieldValueHistory[]

  @@unique([slideId, templateFieldId])
}

model FieldValueHistory {
  id                String          @id @default(uuid())
  slideFieldValueId String
  slideFieldValue   SlideFieldValue @relation(fields: [slideFieldValueId], references: [id], onDelete: Cascade)
  oldValue          String
  newValue          String
  changedBy         String
  changedAt         DateTime        @default(now())
}

model SlideBlockValue {
  id              String        @id @default(uuid())
  slideId         String
  slide           Slide         @relation(fields: [slideId], references: [id], onDelete: Cascade)
  templateBlockId String
  templateBlock   TemplateBlock @relation(fields: [templateBlockId], references: [id])
  value           Json          @default("{}")

  history         BlockValueHistory[]
  chartImageAsset ChartImageAsset?

  @@unique([slideId, templateBlockId])
}

model BlockValueHistory {
  id                String          @id @default(uuid())
  slideBlockValueId String
  slideBlockValue   SlideBlockValue @relation(fields: [slideBlockValueId], references: [id], onDelete: Cascade)
  oldValue          Json
  newValue          Json
  changedBy         String
  changedAt         DateTime        @default(now())
}

model ChartImageAsset {
  id                String          @id @default(uuid())
  slideBlockValueId String          @unique
  slideBlockValue   SlideBlockValue @relation(fields: [slideBlockValueId], references: [id], onDelete: Cascade)
  extension         String
  mimeType          String
  originalFilename  String
  sizeBytes         Int
  uploadedBy        String
  createdAt         DateTime        @default(now())
}

model Presentation {
  id            String      @id @default(uuid())
  weeklyCycleId String      @unique
  weeklyCycle   WeeklyCycle @relation(fields: [weeklyCycleId], references: [id])
  assembledAt   DateTime    @default(now())

  slides PresentationSlide[]
}

model PresentationSlide {
  id               String       @id @default(uuid())
  presentationId   String
  presentation     Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  slideId          String?      @unique
  slide            Slide?       @relation(fields: [slideId], references: [id])
  placeholderLabel String?
  order            Int          @default(0)
}

model AuditLogEntry {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  targetType String?
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  recipient     User             @relation(fields: [recipientId], references: [id])
  type          NotificationType
  weeklyCycleId String
  weeklyCycle   WeeklyCycle      @relation(fields: [weeklyCycleId], references: [id])
  message       String
  createdAt     DateTime         @default(now())
  readAt        DateTime?
  hiddenAt      DateTime?

  @@index([recipientId, hiddenAt])
}
