# Скопируйте в .env и заполните реальными значениями. .env не должен попадать в git.

DATABASE_URL="postgresql://weekly_report:change_me@localhost:5432/weekly_report"

# Сгенерируйте длинную случайную строку, например: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

PORT=4000
NODE_ENV="development"
CLIENT_ORIGIN="http://localhost:5173"

# Используются только скриптом seed.ts при первом запуске (создание первого администратора)
SEED_ADMIN_LOGIN="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
